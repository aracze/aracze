# Šablona proměnných prostředí pro produkční nasazení.
# Na serveru zkopíruj do /opt/aracze/.env a doplň skutečné hodnoty.
# TENTO SOUBOR NEDÁVEJ DO GITU se skutečnými hodnotami!

# --- Databáze PostgreSQL ---
# Uživatel "postgres" (výchozí superuser image); počítají s ním DATABASE_URL
# i pomocné skripty v tomto README.
POSTGRES_USER=postgres
# Silné heslo vygeneruj příkazem:  openssl rand -base64 24
POSTGRES_PASSWORD=ZMEN_ME_silne_heslo
POSTGRES_DB=aracze

# --- Payload CMS ---
# Tajný klíč pro Payload (podpisy, šifrování). Vygeneruj:  openssl rand -hex 32
PAYLOAD_SECRET=ZMEN_ME_nahodny_klic

# --- Inicializace schématu (viz README, sekce 3) ---
# Migrace při startu standardně NEBĚŽÍ (schéma se v produkci řeší importem
# databázového dumpu z lokálu). Zapni jen pro čistý deploy bez dumpu:
# PAYLOAD_RUN_MIGRATIONS=true
# Povolit bootstrap endpoint POST /api/init-db (dělá DROP SCHEMA prázdné DB)?
# Standardně NE:
# ALLOW_INIT_DB=true

# --- Cloudinary (ukládání obrázků) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Frontend ---
# Veřejná adresa webu (zatím IP, po pořízení domény sem přijde https://domena.cz)
SITE_URL=http://217.154.225.117
