DATABASE_URL=postgres://postgres:yourpassword@127.0.0.1:5432/aracze
PAYLOAD_SECRET=YOUR_SECRET_HERE
CLOUDINARY_CLOUD_NAME=<cloudinary_cloud_name>
CLOUDINARY_API_KEY=<cloudinary_api_key>
CLOUDINARY_API_SECRET=<cloudinary_api_secret>
S3_ENDPOINT=<s3_endpoint>
S3_BUCKET=<s3_bucket>
S3_ACCESS_KEY_ID=<s3_access_key_id>
S3_SECRET=<s3_secret>

# Google Maps (mapy na stránkách míst) – veřejný klíč, prochází do prohlížeče.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<google_maps_api_key>
# OpenWeather (endpoint /api/weather) – serverový klíč, do prohlížeče NEprochází.
OPENWEATHER_API_KEY=<openweather_api_key>

# Veřejná URL webu (sitemap, kanonické odkazy). Default https://www.ara.cz.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Base URL Payload API pro absolutní URL obrázků (server i prohlížeč).
PAYLOAD_BASE_API_URL=http://localhost:3000
NEXT_PUBLIC_PAYLOAD_BASE_URL=http://localhost:3000

# Google AdSense (reklamní bloky v článcích) – volitelné.
NEXT_PUBLIC_ADSENSE_CLIENT=<adsense_client_id>
NEXT_PUBLIC_ADSENSE_ARTICLE_SLOT=<adsense_slot_id>
NEXT_PUBLIC_ADSENSE_ARTICLE_SLOT_2=<adsense_slot_id_2>

# PG_DUMP_DOCKER_SERVICE=postgres
# PG_DUMP_DOCKER_HOST=localhost
# PG_DUMP_DOCKER_CONTAINER=postgres-1

# Povolení destruktivního endpointu POST /api/init-db (DROP SCHEMA + rebuild).
# Registruje se JEN když je "true"; volá se s hlavičkou `x-init-secret: <PAYLOAD_SECRET>`.
# V produkci nechat NEnastavené (schéma se řeší importem dumpu). Jen pro bootstrap.
# ALLOW_INIT_DB=true

# --- Migrace ze starého webu (jen pro skripty `pnpm migrate:*`) ---
# Připojení ke staré databázi; v běžném provozu NEjsou potřeba.
# OLD_DB_HOST=
# OLD_DB_PORT=5432
# OLD_DB_USER=
# OLD_DB_PASSWORD=
# OLD_DB_NAME=
