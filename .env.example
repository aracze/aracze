DATABASE_URL=postgres://postgres:yourpassword@127.0.0.1:5432/aracze
PAYLOAD_SECRET=YOUR_SECRET_HERE
CLOUDINARY_CLOUD_NAME=<cloudinary_cloud_name>
CLOUDINARY_API_KEY=<cloudinary_api_key>
CLOUDINARY_API_SECRET=<cloudinary_api_secret>
S3_ENDPOINT=<s3_endpoint>
S3_BUCKET=<s3_bucket>
S3_ACCESS_KEY_ID=<s3_access_key_id>
S3_SECRET=<s3_secret>

# Produkční Cloudinary účet – používá JEN zálohovací skript `scripts/backup-r2.ts`.
# Do R2 se zálohují jen obrázky z tohoto účtu; lokálně nahrané obrázky (dev účet
# v CLOUDINARY_CLOUD_NAME) se přeskočí. Default (bez nastavení): "ara".
# PROD_CLOUDINARY_CLOUD_NAME=ara

# Google Maps (mapy na stránkách míst) – veřejný klíč, prochází do prohlížeče.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<google_maps_api_key>
# Google Maps – Map ID (Cloud Console → Map Management). Nutné pro nový typ
# značky (AdvancedMarkerElement). Bez něj kód spadne na klasickou značku.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=<google_maps_map_id>
# OpenWeather (endpoint /api/weather) – serverový klíč, do prohlížeče NEprochází.
OPENWEATHER_API_KEY=<openweather_api_key>

# SMTP pro odesílání e-mailů z administrace (reset hesla). Bez SMTP_HOST se
# e-maily jen vypíšou do konzole (žádné odesílání). Původní web používal Zoho.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=<smtp_username>
SMTP_PASSWORD=<smtp_password>
SMTP_FROM=info@ara.cz

# Veřejná URL webu (sitemap, kanonické odkazy). Default https://www.ara.cz.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Base URL pro absolutní URL obrázků (loga, avatary, sdílení). Dostupné i v prohlížeči.
NEXT_PUBLIC_PAYLOAD_BASE_URL=http://localhost:3000

# Google AdSense (reklamní bloky v článcích) – volitelné.
NEXT_PUBLIC_ADSENSE_CLIENT=<adsense_client_id>
NEXT_PUBLIC_ADSENSE_ARTICLE_SLOT=<adsense_slot_id>
NEXT_PUBLIC_ADSENSE_ARTICLE_SLOT_2=<adsense_slot_id_2>

# Cloudflare Turnstile – ochrana formuláře komentářů proti spamu (volitelné).
# Oba klíče čte SERVER za běhu (site key se klientovi předává přes prop, proto
# NENÍ NEXT_PUBLIC_ a nevyžaduje rebuild). Bez klíčů jede neviditelný honeypot +
# rate-limit. Klíče získáš na dash.cloudflare.com → Turnstile.
TURNSTILE_SITE_KEY=<turnstile_site_key>
TURNSTILE_SECRET_KEY=<turnstile_secret_key>

# PG_DUMP_DOCKER_SERVICE=postgres
# PG_DUMP_DOCKER_HOST=localhost
# PG_DUMP_DOCKER_CONTAINER=postgres-1

# --- Migrace ze starého webu (jen pro skripty `pnpm migrate:*`) ---
# Připojení ke staré databázi; v běžném provozu NEjsou potřeba.
# OLD_DB_HOST=
# OLD_DB_PORT=5432
# OLD_DB_USER=
# OLD_DB_PASSWORD=
# OLD_DB_NAME=
